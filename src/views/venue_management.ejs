<%- include('partials/header', { title: 'Manajemen Venue - TikTakTuk' }) %>

  <% const isAdminOrOrganizer=user && (user.role==='ADMIN' || user.role==='ORGANIZER' ); const venueList=typeof venues
    !=='undefined' && Array.isArray(venues) ? venues : []; const cities=[...new Set(venueList.map(v=>
    v.city).filter(Boolean))].sort();
    %>

    <div class="seat-page">
      <div class="seat-shell">

        <!-- Header -->
        <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-6">
          <div class="page-heading">
            <h1
              style="font-size:clamp(1.6rem,3vw,2.2rem);font-weight:800;color:var(--ink);letter-spacing:-0.03em;line-height:1.2;">
              Manajemen Venue</h1>
            <p class="auth-muted" style="margin-top:0.3rem;">Cari atau kelola venue anda</p>
          </div>
          <% if (isAdminOrOrganizer) { %>
            <div class="flex gap-3">
              <button type="button" onclick="openAddModal()"
                class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full font-bold text-sm text-white"
                style="background:linear-gradient(145deg,var(--accent),#a87542);box-shadow:0 10px 20px rgba(131,88,42,.16);">Tambah
                Venue</button>
              <a href="#venue-list"
                class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full font-bold text-sm border"
                style="border-color:var(--border);background:rgba(255,255,255,.8);color:var(--ink);">Ke Daftar Venue</a>
            </div>
            <% } %>
        </div>

        <!-- Stats -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
          <div class="seat-card" style="padding:1.2rem 1.1rem;">
            <div class="text-[10px] font-bold uppercase tracking-widest" style="color:#94a3b8;">Total Venue</div>
            <div class="seat-stat-value" style="margin-top:.45rem;">
              <%= typeof totalVenues !=='undefined' ? totalVenues : 0 %>
            </div>
          </div>
          <div class="seat-card" style="padding:1.2rem 1.1rem;">
            <div class="text-[10px] font-bold uppercase tracking-widest" style="color:#94a3b8;">Reserved Seating</div>
            <div class="seat-stat-value" style="margin-top:.45rem;">
              <%= typeof reservedCount !=='undefined' ? reservedCount : 0 %>
            </div>
          </div>
          <div class="seat-card" style="padding:1.2rem 1.1rem;">
            <div class="text-[10px] font-bold uppercase tracking-widest" style="color:#94a3b8;">Free Seating</div>
            <div class="seat-stat-value" style="margin-top:.45rem;">
              <%= typeof freeCount !=='undefined' ? freeCount : 0 %>
            </div>
          </div>
          <div class="seat-card" style="padding:1.2rem 1.1rem;">
            <div class="text-[10px] font-bold uppercase tracking-widest" style="color:#94a3b8;">Total Kapasitas</div>
            <div class="seat-stat-value" style="margin-top:.45rem;">
              <%= typeof totalCapacity !=='undefined' ? totalCapacity : 0 %>
            </div>
          </div>
        </div>

        <!-- Daftar Venue -->
        <div class="seat-card" style="padding:1.5rem;" id="venue-list">
          <div style="margin-bottom:1.2rem;">
            <h2 style="font-size:1.25rem;font-weight:800;color:var(--ink);">Daftar Venue</h2>
            <p class="auth-muted" style="margin-top:0.2rem;font-size:0.88rem;">Cari berdasarkan nama atau alamat, lalu
              filter berdasarkan kota dan jenis seating.</p>
          </div>

          <!-- Search & Filter -->
          <div class="seat-toolbar" style="margin-bottom:1.2rem;">
            <input type="text" id="venue-search" placeholder="Cari nama venue atau alamat" class="form-input"
              style="grid-column:span 1;">
            <select id="venue-filter-city" class="form-input">
              <option value="">Semua Kota</option>
              <% cities.forEach(function(city) { %>
                <option value="<%= city %>">
                  <%= city %>
                </option>
                <% }) %>
            </select>
            <select id="venue-filter-seating" class="form-input">
              <option value="">Semua Seating</option>
              <option value="reserved">Reserved</option>
              <option value="free">Free Seating</option>
            </select>
            <button type="button" onclick="resetFilters()"
              class="inline-flex items-center justify-center gap-2 px-4 py-2 rounded-xl font-bold text-sm"
              style="border:1px solid var(--border);background:rgba(255,255,255,.8);color:var(--ink);">Reset
              Filter</button>
          </div>

          <!-- Venue Cards Grid -->
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4" id="venue-cards">
            <% if (venueList.length> 0) { %>
              <% venueList.forEach(function(venue) { %>
                <div class="venue-card-item"
                  style="border:1px solid var(--border);border-radius:18px;padding:1.1rem;background:rgba(255,255,255,.82);box-shadow:0 4px 14px rgba(83,58,28,.05);"
                  data-name="<%= (venue.name || '').toLowerCase() %>"
                  data-address="<%= (venue.address || '').toLowerCase() %>"
                  data-city="<%= (venue.city || '').toLowerCase() %>"
                  data-seating="<%= venue.has_seats ? 'reserved' : 'free' %>">
                  <div class="flex justify-between items-start mb-2">
                    <div class="flex items-start gap-2">
                      <div
                        style="width:28px;height:28px;border-radius:50%;background:var(--surface-soft);display:flex;align-items:center;justify-content:center;margin-top:2px;">
                        <svg style="width:14px;height:14px;color:var(--muted);" fill="none" stroke="currentColor"
                          viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                        </svg>
                      </div>
                      <div>
                        <h3 style="font-size:1rem;font-weight:700;color:var(--ink);">
                          <%= venue.name %>
                        </h3>
                        <p style="font-size:0.82rem;color:var(--muted);margin-top:1px;">
                          <%= venue.address %>, <%= venue.city %>
                        </p>
                      </div>
                    </div>
                    <% if (venue.has_seats) { %>
                      <span class="seat-pill is-reserved" style="font-size:0.7rem;">Reserved</span>
                      <% } else { %>
                        <span class="seat-pill is-free" style="font-size:0.7rem;">Free seating</span>
                        <% } %>
                  </div>

                  <div
                    style="font-size:0.82rem;color:var(--muted);margin:0.6rem 0 0.8rem;display:flex;align-items:center;gap:0.35rem;">
                    <svg style="width:13px;height:13px;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M4 8V4m0 0h4M4 4l5 5m11-1V4m0 0h-4m4 0l-5 5M4 16v4m0 0h4m-4 0l5-5m11 5l-5-5m5 5v-4m0 4h-4" />
                    </svg>
                    <span>
                      <%= new Intl.NumberFormat('id-ID').format(venue.capacity || 0) %> seat
                    </span>
                  </div>

                  <% if (isAdminOrOrganizer) { %>
                    <div style="display:flex;gap:0.5rem;border-top:1px solid var(--border);padding-top:0.7rem;">
                      <button type="button"
                        data-venue="<%= JSON.stringify({id:venue.id,name:venue.name,city:venue.city,address:venue.address,capacity:venue.capacity,has_seats:venue.has_seats}) %>"
                        onclick="openEditModal(JSON.parse(this.dataset.venue))"
                        class="btn-edit-premium">
                        <svg style="width:13px;height:13px;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                        </svg>
                        Edit
                      </button>
                      <button type="button" onclick='openDeleteModal("<%= venue.id %>","<%= venue.name %>")'
                        class="btn-hapus-premium">
                        <svg style="width:13px;height:13px;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                        </svg>
                        Hapus
                      </button>
                    </div>
                    <% } %>
                </div>
                <% }) %>
                  <% } else { %>
                    <div style="grid-column:1/-1;text-align:center;padding:2rem;color:var(--muted);">Belum ada venue
                      terdaftar.</div>
                    <% } %>
          </div>
        </div>
      </div>
    </div>

    <!-- Add Modal -->
    <div class="seat-modal" id="modal-add-venue">
      <div class="seat-modal-panel">
        <div
          style="padding:1.25rem;display:flex;justify-content:space-between;align-items:flex-start;border-bottom:1px solid rgba(185,133,78,.14);">
          <div>
            <h2 style="font-size:1.35rem;font-weight:800;color:var(--ink);">Tambah Venue</h2>
            <p class="auth-muted" style="margin-top:0.3rem;">Isi data venue baru anda</p>
          </div>
          <button type="button" onclick="closeModal('modal-add-venue')" class="auth-modal-close">x</button>
        </div>
        <form id="form-add-venue" style="padding:1.25rem;">
          <div class="seat-form-grid">
            <div>
              <label class="seat-form-label">Nama Venue</label>
              <input type="text" name="venue_name" class="form-input" placeholder="Masukkan nama venue" required>
            </div>
            <div>
              <label class="seat-form-label">Kota</label>
              <input type="text" name="city" class="form-input" placeholder="Masukkan nama kota" required>
            </div>
            <div class="seat-form-field-full">
              <label class="seat-form-label">Alamat</label>
              <textarea name="address" class="form-input" placeholder="Masukkan alamat lengkap venue" rows="3"
                required></textarea>
            </div>
            <div>
              <label class="seat-form-label">Kapasitas</label>
              <input type="number" name="capacity" class="form-input" placeholder="Contoh: 1200" min="1" required>
            </div>
            <div style="display:flex;align-items:flex-end;padding-bottom:0.2rem;">
              <label class="inline-check" style="cursor:pointer;">
                <input type="checkbox" name="has_reserved_seating"
                  style="margin-top:0.28rem;accent-color:var(--accent);width:18px;height:18px;">
                <span style="font-size:0.88rem;font-weight:600;">This venue has reserved seating</span>
              </label>
            </div>
          </div>
          <div style="display:flex;gap:0.75rem;margin-top:1.5rem;">
            <button type="button" onclick="closeModal('modal-add-venue')"
              style="flex:0 0 auto;padding:0.75rem 2rem;border-radius:999px;font-weight:700;border:none;background:#dc2626;color:#fff;cursor:pointer;">Batal</button>
            <button type="submit"
              style="flex:1;padding:0.75rem 2rem;border-radius:999px;font-weight:700;border:none;background:linear-gradient(145deg,var(--accent),#a87542);color:#fff;cursor:pointer;box-shadow:0 10px 20px rgba(131,88,42,.16);">Simpan</button>
          </div>
        </form>
      </div>
    </div>

    <!-- Edit Modal -->
    <div class="seat-modal" id="modal-edit-venue">
      <div class="seat-modal-panel">
        <div
          style="padding:1.25rem;display:flex;justify-content:space-between;align-items:flex-start;border-bottom:1px solid rgba(185,133,78,.14);">
          <div>
            <h2 style="font-size:1.35rem;font-weight:800;color:var(--ink);">Edit Venue</h2>
            <p class="auth-muted" style="margin-top:0.3rem;">Perbarui data venue anda.</p>
          </div>
          <button type="button" onclick="closeModal('modal-edit-venue')" class="auth-modal-close">x</button>
        </div>
        <form id="form-edit-venue" style="padding:1.25rem;">
          <input type="hidden" name="venue_id" id="edit-venue-id">
          <div class="seat-form-grid">
            <div>
              <label class="seat-form-label">Nama Venue</label>
              <input type="text" name="venue_name" id="edit-venue-name" class="form-input" required>
            </div>
            <div>
              <label class="seat-form-label">Kota</label>
              <input type="text" name="city" id="edit-venue-city" class="form-input" required>
            </div>
            <div class="seat-form-field-full">
              <label class="seat-form-label">Alamat</label>
              <textarea name="address" id="edit-venue-address" class="form-input" rows="3" required></textarea>
            </div>
            <div>
              <label class="seat-form-label">Kapasitas</label>
              <input type="number" name="capacity" id="edit-venue-capacity" class="form-input" min="1" required>
            </div>
            <div style="display:flex;align-items:flex-end;padding-bottom:0.2rem;">
              <label class="inline-check" style="cursor:pointer;">
                <input type="checkbox" name="has_reserved_seating" id="edit-venue-seating"
                  style="margin-top:0.28rem;accent-color:var(--accent);width:18px;height:18px;">
                <span style="font-size:0.88rem;font-weight:600;">This venue has reserved seating</span>
              </label>
            </div>
          </div>
          <div style="display:flex;gap:0.75rem;margin-top:1.5rem;">
            <button type="button" onclick="closeModal('modal-edit-venue')"
              style="flex:0 0 auto;padding:0.75rem 2rem;border-radius:999px;font-weight:700;border:none;background:#dc2626;color:#fff;cursor:pointer;">Batal</button>
            <button type="submit"
              style="flex:1;padding:0.75rem 2rem;border-radius:999px;font-weight:700;border:none;background:linear-gradient(145deg,var(--accent),#a87542);color:#fff;cursor:pointer;box-shadow:0 10px 20px rgba(131,88,42,.16);">Simpan
              Perubahan</button>
          </div>
        </form>
      </div>
    </div>

    <!-- Delete Confirmation Modal -->
    <div class="seat-modal" id="modal-delete-venue">
      <div class="seat-modal-panel seat-modal-panel--narrow">
        <div
          style="padding:1.25rem;display:flex;justify-content:space-between;align-items:flex-start;border-bottom:1px solid rgba(185,133,78,.14);">
          <h2 style="font-size:1.35rem;font-weight:800;color:var(--ink);">Hapus Venue</h2>
          <button type="button" onclick="closeModal('modal-delete-venue')" class="auth-modal-close">x</button>
        </div>
        <div style="padding:1.25rem;">
          <div
            style="padding:1rem;border-radius:14px;background:var(--surface-soft);color:var(--muted);line-height:1.6;">
            Anda akan menghapus <strong id="delete-venue-name" style="color:var(--ink);"></strong> dari daftar venue.
            Tindakan ini tidak dapat dibatalkan.
          </div>
          <input type="hidden" id="delete-venue-id">
          <div style="display:flex;justify-content:flex-end;gap:0.75rem;margin-top:1.25rem;">
            <button type="button" onclick="closeModal('modal-delete-venue')"
              style="padding:0.6rem 1.5rem;border-radius:999px;font-weight:700;border:1px solid var(--border);background:rgba(255,255,255,.8);color:var(--ink);cursor:pointer;">Batal</button>
            <button type="button" onclick="confirmDelete()" class="inline-flex items-center gap-2"
              style="padding:0.6rem 1.5rem;border-radius:999px;font-weight:700;border:none;background:#dc2626;color:#fff;cursor:pointer;">
              <svg style="width:14px;height:14px;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
              </svg>
              Hapus
            </button>
          </div>
        </div>
      </div>
    </div>

    <script>
      (function () {
        // Modal helpers
        window.openModal = function (id) { document.getElementById(id).classList.add('is-open'); document.body.style.overflow = 'hidden'; };
        window.closeModal = function (id) { document.getElementById(id).classList.remove('is-open'); document.body.style.overflow = ''; };

        // Search & Filter
        const searchInput = document.getElementById('venue-search');
        const filterCity = document.getElementById('venue-filter-city');
        const filterSeating = document.getElementById('venue-filter-seating');
        const cards = document.querySelectorAll('.venue-card-item');

        function applyFilters() {
          const q = (searchInput.value || '').toLowerCase();
          const city = (filterCity.value || '').toLowerCase();
          const seating = filterSeating.value || '';
          cards.forEach(card => {
            const matchName = card.dataset.name.includes(q) || card.dataset.address.includes(q);
            const matchCity = !city || card.dataset.city === city;
            const matchSeating = !seating || card.dataset.seating === seating;
            card.style.display = matchName && matchCity && matchSeating ? '' : 'none';
          });
        }

        if (searchInput) searchInput.addEventListener('input', applyFilters);
        if (filterCity) filterCity.addEventListener('change', applyFilters);
        if (filterSeating) filterSeating.addEventListener('change', applyFilters);

        window.resetFilters = function () {
          if (searchInput) searchInput.value = '';
          if (filterCity) filterCity.value = '';
          if (filterSeating) filterSeating.value = '';
          cards.forEach(card => card.style.display = '');
        };

        // Open Add Modal
        window.openAddModal = function () { openModal('modal-add-venue'); };

        // Open Edit Modal
        window.openEditModal = function (venue) {
          document.getElementById('edit-venue-id').value = venue.id;
          document.getElementById('edit-venue-name').value = venue.name;
          document.getElementById('edit-venue-city').value = venue.city;
          document.getElementById('edit-venue-address').value = venue.address;
          document.getElementById('edit-venue-capacity').value = venue.capacity;
          document.getElementById('edit-venue-seating').checked = venue.has_seats;
          openModal('modal-edit-venue');
        };

        // Open Delete Modal
        window.openDeleteModal = function (id, name) {
          document.getElementById('delete-venue-id').value = id;
          document.getElementById('delete-venue-name').textContent = name;
          openModal('modal-delete-venue');
        };

        // Add Venue
        document.getElementById('form-add-venue').addEventListener('submit', async function (e) {
          e.preventDefault();
          const fd = new FormData(this);
          try {
            const res = await fetch('/api/venues', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                venue_name: fd.get('venue_name'),
                city: fd.get('city'),
                address: fd.get('address'),
                capacity: Number(fd.get('capacity')),
                has_reserved_seating: !!fd.get('has_reserved_seating')
              })
            });
            const data = await res.json();
            if (data.success) {
              closeModal('modal-add-venue');
              showSuccessToast(data.message || 'Venue berhasil ditambahkan');
              setTimeout(() => location.reload(), 800);
            } else {
              showErrorToast(data.message || 'Gagal menambahkan venue');
            }
          } catch (err) {
            showErrorToast('Error: ' + err.message);
          }
        });

        // Edit Venue
        document.getElementById('form-edit-venue').addEventListener('submit', async function (e) {
          e.preventDefault();
          const fd = new FormData(this);
          const venueId = fd.get('venue_id');
          try {
            const res = await fetch('/api/venues/' + venueId, {
              method: 'PUT',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                venue_name: fd.get('venue_name'),
                city: fd.get('city'),
                address: fd.get('address'),
                capacity: Number(fd.get('capacity')),
                has_reserved_seating: !!fd.get('has_reserved_seating')
              })
            });
            const data = await res.json();
            if (data.success) {
              closeModal('modal-edit-venue');
              showSuccessToast(data.message || 'Venue berhasil diperbarui');
              setTimeout(() => location.reload(), 800);
            } else {
              showErrorToast(data.message || 'Gagal memperbarui venue');
            }
          } catch (err) {
            showErrorToast('Error: ' + err.message);
          }
        });

        // Delete Venue
        window.confirmDelete = async function () {
          const venueId = document.getElementById('delete-venue-id').value;
          try {
            const res = await fetch('/api/venues/' + venueId, {
              method: 'DELETE',
              headers: { 'Content-Type': 'application/json' }
            });
            const data = await res.json();
            if (data.success) {
              closeModal('modal-delete-venue');
              showSuccessToast(data.message || 'Venue berhasil dihapus');
              setTimeout(() => location.reload(), 800);
            } else {
              showErrorToast(data.message || 'Gagal menghapus venue');
            }
          } catch (err) {
            showErrorToast('Error: ' + err.message);
          }
        };

        // Close on Escape
        document.addEventListener('keydown', function (e) {
          if (e.key === 'Escape') {
            ['modal-add-venue', 'modal-edit-venue', 'modal-delete-venue'].forEach(id => {
              const el = document.getElementById(id);
              if (el && el.classList.contains('is-open')) closeModal(id);
            });
          }
        });
      })();
    </script>

    <%- include('partials/footer') %>