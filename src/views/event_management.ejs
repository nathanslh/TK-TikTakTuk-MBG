<%- include('partials/header', { title: 'Manajemen Event - TikTakTuk' }) %>

  <% const isAdminOrOrganizer=user && (user.role==='ADMIN' || user.role==='ORGANIZER' ); const eventList=typeof events
    !=='undefined' && Array.isArray(events) ? events : []; const venueList=typeof venues !=='undefined' &&
    Array.isArray(venues) ? venues : []; const organizerList=typeof organizers !=='undefined' &&
    Array.isArray(organizers) ? organizers : []; %>

    <div class="seat-page">
      <div class="seat-shell">
        <!-- Header -->
        <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-6">
          <div class="page-heading">
            <h1 style="font-size:clamp(1.6rem,3vw,2.2rem);font-weight:800;color:var(--ink);letter-spacing:-0.03em;">
              Manajemen Event</h1>
            <p class="auth-muted" style="margin-top:0.3rem;">Cari atau kelola event anda</p>
          </div>
          <% if (isAdminOrOrganizer) { %>
            <div class="flex gap-3">
              <button type="button" onclick="openCreateModal()"
                class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full font-bold text-sm text-white"
                style="background:linear-gradient(145deg,var(--accent),#a87542);box-shadow:0 10px 20px rgba(131,88,42,.16);">Buat
                Acara</button>
              <a href="#event-list"
                class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full font-bold text-sm border"
                style="border-color:var(--border);background:rgba(255,255,255,.8);color:var(--ink);">Ke Daftar Event</a>
            </div>
            <% } %>
        </div>

        <!-- Stats -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
          <div class="seat-card" style="padding:1.2rem 1.1rem;">
            <div class="text-[10px] font-bold uppercase tracking-widest" style="color:#94a3b8;">Total Event</div>
            <div class="seat-stat-value" style="margin-top:.45rem;">
              <%= typeof totalEvents !=='undefined' ? totalEvents : 0 %>
            </div>
          </div>
          <div class="seat-card" style="padding:1.2rem 1.1rem;">
            <div class="text-[10px] font-bold uppercase tracking-widest" style="color:#94a3b8;">Event Mendatang</div>
            <div class="seat-stat-value" style="margin-top:.45rem;">
              <%= typeof upcomingCount !=='undefined' ? upcomingCount : 0 %>
            </div>
          </div>
          <div class="seat-card" style="padding:1.2rem 1.1rem;">
            <div class="text-[10px] font-bold uppercase tracking-widest" style="color:#94a3b8;">Total Artist</div>
            <div class="seat-stat-value" style="margin-top:.45rem;">
              <%= typeof totalArtists !=='undefined' ? totalArtists : 0 %>
            </div>
          </div>
          <div class="seat-card" style="padding:1.2rem 1.1rem;">
            <div class="text-[10px] font-bold uppercase tracking-widest" style="color:#94a3b8;">Total Kategori</div>
            <div class="seat-stat-value" style="margin-top:.45rem;">
              <%= typeof totalCategories !=='undefined' ? totalCategories : 0 %>
            </div>
          </div>
        </div>

        <!-- Event List -->
        <div class="seat-card" style="padding:1.5rem;" id="event-list">
          <div style="margin-bottom:1.2rem;">
            <h2 style="font-size:1.25rem;font-weight:800;color:var(--ink);">Daftar Event</h2>
            <p class="auth-muted" style="margin-top:0.2rem;font-size:0.88rem;">Cari berdasarkan judul atau artist, lalu
              filter berdasarkan venue.</p>
          </div>

          <div class="seat-toolbar" style="margin-bottom:1.2rem;">
            <input type="text" id="event-search" placeholder="Cari judul event atau artist" class="form-input"
              style="grid-column:span 2;">
            <select id="event-filter-venue" class="form-input">
              <option value="">Semua Venue</option>
              <% venueList.forEach(function(v) { %>
                <option value="<%= v.venue_name %>">
                  <%= v.venue_name %>
                </option>
                <% }) %>
            </select>
            <button type="button" onclick="resetEventFilters()"
              class="inline-flex items-center justify-center gap-2 px-4 py-2 rounded-xl font-bold text-sm"
              style="border:1px solid var(--border);background:rgba(255,255,255,.8);color:var(--ink);">Reset
              Filter</button>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-4" id="event-cards">
            <% if (eventList.length> 0) { %>
              <% eventList.forEach(function(evt) { %>
                <div class="event-card-item"
                  style="border:1px solid var(--border);border-radius:18px;padding:1.1rem;background:rgba(255,255,255,.82);box-shadow:0 4px 14px rgba(83,58,28,.05);"
                  data-title="<%= (evt.event_title || '').toLowerCase() %>"
                  data-artists="<%= (evt.artists || '').toLowerCase() %>"
                  data-venue="<%= (evt.venue_name || '').toLowerCase() %>">
                  <div class="flex justify-between items-start mb-1">
                    <h3 style="font-size:1rem;font-weight:700;color:var(--ink);">
                      <%= evt.event_title %>
                    </h3>
                    <span class="seat-pill" style="font-size:0.68rem;white-space:nowrap;">
                      <%= evt.venue_name %>
                    </span>
                  </div>
                  <p style="font-size:0.82rem;color:var(--muted);margin-bottom:0.3rem;">
                    <svg style="width:12px;height:12px;display:inline;vertical-align:-1px;margin-right:3px;" fill="none"
                      stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                    </svg>
                    <%= new
                      Date(evt.event_datetime).toLocaleDateString('id-ID',{day:'2-digit',month:'long',year:'numeric'})
                      %> • <%= new
                        Date(evt.event_datetime).toLocaleTimeString('id-ID',{hour:'2-digit',minute:'2-digit'}) %>
                  </p>
                  <p style="font-size:0.78rem;color:var(--muted);">Organizer: <strong>
                      <%= evt.organizer_name %>
                    </strong></p>
                  <% if (evt.artists) { %>
                    <p style="font-size:0.78rem;color:var(--muted);margin-top:2px;">Artist: <%= evt.artists %>
                    </p>
                    <% } %>
                      <% if (evt.categories) { %>
                        <div style="margin-top:0.5rem;display:flex;flex-wrap:wrap;gap:0.3rem;">
                          <% evt.categories.split(', ').forEach(function(cat) { %>
                    <span style="font-size:0.68rem;padding:0.2rem 0.5rem;border-radius:999px;background:rgba(185,133,78,.1);color:var(--accent-strong);font-weight:600;"><%= cat %></span>
                  <% }) %>
                </div>
              <% } %>

              <% if (user && user.role === 'CUSTOMER' && evt.ticket_categories && evt.ticket_categories.length> 0) {
                            %>
                            <% const prices=evt.ticket_categories.map(tc=> Number(tc.price));
                              const minPrice = Math.min(...prices);
                              const formattedPrice = new Intl.NumberFormat('id-ID', { style: 'currency', currency:
                              'IDR', maximumFractionDigits: 0 }).format(minPrice);
                              %>
                              <div style="margin-top:0.6rem;padding-top:0.6rem;border-top:1px dashed var(--border); display:flex; justify-content:space-between; align-items:center; gap:0.5rem;">
                                <div>
                                  <p style="font-size:0.75rem;color:var(--muted);margin:0;">Harga tiket</p>
                                  <p style="font-size:0.95rem;color:var(--ink);font-weight:800;margin:0;">Mulai dari <span
                                      style="color:var(--accent-strong);">
                                      <%= formattedPrice %>
                                    </span></p>
                                </div>
                                <a href="/checkout/<%= evt.event_id %>?username=<%= encodeURIComponent(user.username) %>" 
                                   class="inline-flex items-center gap-1.5 px-4 py-2 rounded-full font-bold text-xs text-white transition-all hover:scale-105" 
                                   style="background: linear-gradient(145deg, var(--accent), #a87542); box-shadow: 0 4px 10px rgba(131,88,42,.2); text-decoration: none; color: white;">
                                  Beli Tiket
                                </a>
                              </div>
                              <% } %>

                                <% if (isAdminOrOrganizer) { %>
                                  <div
                                    style="display:flex;gap:0.5rem;border-top:1px solid var(--border);padding-top:0.7rem;margin-top:0.7rem;">
                                    <button type="button"
                                      data-event="<%= JSON.stringify({id:evt.event_id,title:evt.event_title,date:new Date(evt.event_datetime).toISOString().split('T')[0],time:new Date(evt.event_datetime).toTimeString().slice(0,5),venue_id:evt.venue_id,venue_name:evt.venue_name,organizer_id:evt.organizer_id,artist_ids:evt.artist_ids||'',description:evt.description||'',ticket_categories:evt.ticket_categories||[]}) %>"
                                      onclick="openEditModal(JSON.parse(this.dataset.event))"
                                      class="btn-edit-premium">
                                      <svg style="width:13px;height:13px;" fill="none" stroke="currentColor"
                                        viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                          d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                                      </svg>
                                      Edit
                                    </button>
                                  </div>
                                  <% } %>
                        </div>
                        <% }) %>
                          <% } else { %>
                            <div style="grid-column:1/-1;text-align:center;padding:2rem;color:var(--muted);">Belum ada
                              event terdaftar.</div>
                            <% } %>
                </div>
          </div>
      </div>

      <!-- Create/Edit Modal -->
      <div class="seat-modal" id="modal-event-form">
        <div class="seat-modal-panel" style="max-width:680px;max-height:90vh;overflow-y:auto;">
          <div
            style="padding:1.25rem;display:flex;justify-content:space-between;align-items:flex-start;border-bottom:1px solid rgba(185,133,78,.14);position:sticky;top:0;background:linear-gradient(180deg,rgba(255,253,248,.98),rgba(249,243,233,.98));z-index:2;">
            <div>
              <h2 id="event-modal-title" style="font-size:1.35rem;font-weight:800;color:var(--ink);">Buat Event</h2>
              <p id="event-modal-copy" class="auth-muted" style="margin-top:0.3rem;">Isi data acara berikut untuk
                menambahkan event baru ke katalog TikTakTuk.</p>
            </div>
            <button type="button" onclick="closeModal('modal-event-form')" class="auth-modal-close">x</button>
          </div>
          <form id="form-event" style="padding:1.25rem;">
            <input type="hidden" name="event_id" id="fe-event-id">
            <input type="hidden" name="mode" id="fe-mode" value="create">

            <div class="seat-form-grid">
              <div>
                <label class="seat-form-label">Event ID</label>
                <input type="text" id="fe-display-id" class="form-input" readonly
                  style="background:#f5f3ef;color:var(--muted);">
              </div>
              <div>
                <label class="seat-form-label">Judul Acara</label>
                <input type="text" name="title" id="fe-title" class="form-input" placeholder="Masukkan judul acara"
                  required>
              </div>
              <div>
                <label class="seat-form-label">Tanggal Acara</label>
                <input type="date" name="date" id="fe-date" class="form-input" required>
              </div>
              <div>
                <label class="seat-form-label">Waktu Acara</label>
                <input type="time" name="time" id="fe-time" class="form-input" required>
              </div>
              <div class="seat-form-field-full">
                <label class="seat-form-label">Venue</label>
                <select name="venue_id" id="fe-venue" class="form-input" required>
                  <option value="">Pilih venue</option>
                  <% venueList.forEach(function(v) { %>
                    <option value="<%= v.venue_id %>">
                      <%= v.venue_name %>
                    </option>
                    <% }) %>
                </select>
              </div>
              <div class="seat-form-field-full">
                <label class="seat-form-label">Daftar Artist / Performer</label>
                <div style="position:relative;">
                  <select id="artist-selector" class="form-input" style="margin-bottom:0.5rem;" onchange="addArtistBadge(this)">
                    <option value="">+ Pilih Artist</option>
                    <% if (typeof artistList !== 'undefined') { %>
                      <% artistList.forEach(function(a) { %>
                        <option value="<%= a.artist_id %>" data-name="<%= a.name %> <%= a.genre ? '('+a.genre+')' : '' %>"><%= a.name %> <%= a.genre ? '('+a.genre+')' : '' %></option>
                      <% }) %>
                    <% } %>
                  </select>
                  <div id="artist-badges" style="display:flex;flex-wrap:wrap;gap:0.5rem;margin-bottom:0.5rem;"></div>
                </div>
              </div>
            </div>

            <!-- Ticket Categories -->
            <div style="margin-top:1.2rem;border-top:1px solid var(--border);padding-top:1rem;">
              <div style="font-size:0.95rem;font-weight:700;color:var(--ink);margin-bottom:0.8rem;">Kategori tiket
                (ticket category)</div>
              <div id="ticket-cat-list"></div>
              <button type="button" onclick="addTicketRow()"
                style="color:var(--accent-strong);font-weight:700;font-size:0.88rem;background:none;border:none;cursor:pointer;margin-top:0.5rem;">+
                Tambah Kategori</button>
            </div>

            <!-- Description -->
            <div style="margin-top:1.2rem;">
              <label class="seat-form-label">Deskripsi Acara</label>
              <textarea name="description" id="fe-description" class="form-input" rows="3"
                placeholder="Tulis ringkasan singkat acara"></textarea>
            </div>

            <div style="display:flex;gap:0.75rem;margin-top:1.5rem;justify-content:flex-end;">
              <button type="button" onclick="closeModal('modal-event-form')"
                style="padding:0.65rem 1.5rem;border-radius:999px;font-weight:700;border:1px solid var(--border);background:rgba(255,255,255,.8);color:var(--ink);cursor:pointer;">Batal</button>
              <button type="submit" id="event-submit-btn"
                style="padding:0.65rem 2rem;border-radius:999px;font-weight:700;border:none;background:linear-gradient(145deg,var(--accent),#a87542);color:#fff;cursor:pointer;box-shadow:0 10px 20px rgba(131,88,42,.16);">Simpan</button>
            </div>
          </form>
        </div>
      </div>

      </div>
      <script>
        (function () {
          let ticketRowIdx = 0;

          window.openModal = function (id) { document.getElementById(id).classList.add('is-open'); document.body.style.overflow = 'hidden'; };
          window.closeModal = function (id) { document.getElementById(id).classList.remove('is-open'); document.body.style.overflow = ''; };

          window.addArtistBadge = function(selectEl) {
            if (!selectEl.value) return;
            const val = selectEl.value;
            const text = selectEl.options[selectEl.selectedIndex].getAttribute('data-name');
            
            // Allow multiple identical badges to trigger SQL validations
            const badgeHTML = '<div class="artist-badge" data-val="'+val+'" style="display:inline-flex;align-items:center;background:var(--surface-soft);border:1px solid var(--border);padding:0.3rem 0.6rem;border-radius:999px;font-size:0.8rem;color:var(--ink);">'+text+'<button type="button" onclick="removeArtistBadge(this)" style="background:none;border:none;margin-left:0.4rem;color:var(--muted);cursor:pointer;font-weight:bold;">&times;</button></div>';
            document.getElementById('artist-badges').insertAdjacentHTML('beforeend', badgeHTML);

            selectEl.value = '';
          };

          window.removeArtistBadge = function(btnEl) {
            const badge = btnEl.closest('.artist-badge');
            if (badge) badge.remove();
          };

          window.syncArtistBadges = function(artistIdsString) {
            const badgesContainer = document.getElementById('artist-badges');
            badgesContainer.innerHTML = '';
            
            if (!artistIdsString) return;
            
            const selectedIds = artistIdsString.split(',');
            selectedIds.forEach(id => {
              const selOpt = document.querySelector('#artist-selector option[value="'+id+'"]');
              if (selOpt) {
                const text = selOpt.getAttribute('data-name');
                const badgeHTML = '<div class="artist-badge" data-val="'+id+'" style="display:inline-flex;align-items:center;background:var(--surface-soft);border:1px solid var(--border);padding:0.3rem 0.6rem;border-radius:999px;font-size:0.8rem;color:var(--ink);">'+text+'<button type="button" onclick="removeArtistBadge(this)" style="background:none;border:none;margin-left:0.4rem;color:var(--muted);cursor:pointer;font-weight:bold;">&times;</button></div>';
                badgesContainer.insertAdjacentHTML('beforeend', badgeHTML);
              }
            });
          };

          // Search & Filter
          const searchInput = document.getElementById('event-search');
          const filterVenue = document.getElementById('event-filter-venue');
          const cards = document.querySelectorAll('.event-card-item');

          function applyEventFilters() {
            const q = (searchInput.value || '').toLowerCase();
            const venue = (filterVenue.value || '').toLowerCase();
            cards.forEach(c => {
              const matchText = c.dataset.title.includes(q) || c.dataset.artists.includes(q);
              const matchVenue = !venue || c.dataset.venue === venue;
              c.style.display = matchText && matchVenue ? '' : 'none';
            });
          }
          if (searchInput) searchInput.addEventListener('input', applyEventFilters);
          if (filterVenue) filterVenue.addEventListener('change', applyEventFilters);
          window.resetEventFilters = function () { if (searchInput) searchInput.value = ''; if (filterVenue) filterVenue.value = ''; cards.forEach(c => c.style.display = ''); };

          // Ticket category rows
          function createTicketRowHTML(data) {
            const idx = ticketRowIdx++;
            const name = data && data.name ? data.name : '';
            const price = data && data.price ? data.price : '';
            const quota = data && data.quota ? data.quota : '';
            return '<div class="ticket-cat-row" style="display:grid;grid-template-columns:2fr 1.5fr 1fr auto;gap:0.5rem;align-items:end;margin-bottom:0.6rem;padding:0.8rem;border:1px solid var(--border);border-radius:14px;background:rgba(255,255,255,.6);">' +
              '<div><div class="seat-form-label">Nama Kategori</div><input type="text" name="tc_name_' + idx + '" class="form-input tc-name" value="' + name + '" placeholder="VVIP" required></div>' +
              '<div><div class="seat-form-label">Harga (Rp)</div><input type="number" name="tc_price_' + idx + '" class="form-input tc-price" value="' + price + '" placeholder="1500000" min="0" required></div>' +
              '<div><div class="seat-form-label">Kuota</div><input type="number" name="tc_quota_' + idx + '" class="form-input tc-quota" value="' + quota + '" placeholder="50" min="1" required></div>' +
              '<button type="button" onclick="this.closest(\'.ticket-cat-row\').remove()" style="width:28px;height:28px;border-radius:50%;border:none;background:rgba(220,38,38,.1);color:#dc2626;font-size:1rem;cursor:pointer;margin-bottom:4px;">×</button>' +
              '</div>';
          }

          window.addTicketRow = function (data) {
            document.getElementById('ticket-cat-list').insertAdjacentHTML('beforeend', createTicketRowHTML(data));
          };

          function generateEventId() { return 'EVT-' + Math.random().toString(36).substring(2, 10).toUpperCase(); }

          // Create Modal
          window.openCreateModal = function () {
            document.getElementById('fe-mode').value = 'create';
            document.getElementById('fe-event-id').value = '';
            document.getElementById('fe-display-id').value = generateEventId();
            document.getElementById('fe-title').value = '';
            document.getElementById('fe-date').value = '';
            document.getElementById('fe-time').value = '';
            document.getElementById('fe-venue').value = '';
            
            syncArtistBadges('');
            
            document.getElementById('fe-description').value = '';
            document.getElementById('ticket-cat-list').innerHTML = '';
            ticketRowIdx = 0;
            addTicketRow({ name: 'VVIP', price: 1500000, quota: 50 });
            addTicketRow({ name: 'VIP', price: 750000, quota: 150 });
            document.getElementById('event-modal-title').textContent = 'Buat Event';
            document.getElementById('event-modal-copy').textContent = 'Isi data acara berikut untuk menambahkan event baru ke katalog TikTakTuk.';
            document.getElementById('event-submit-btn').textContent = 'Simpan';
            openModal('modal-event-form');
          };

          // Edit Modal
          window.openEditModal = function (evt) {
            document.getElementById('fe-mode').value = 'edit';
            document.getElementById('fe-event-id').value = evt.id;
            document.getElementById('fe-display-id').value = evt.id.substring(0, 13).toUpperCase();
            document.getElementById('fe-title').value = evt.title;
            document.getElementById('fe-date').value = evt.date;
            document.getElementById('fe-time').value = evt.time;
            document.getElementById('fe-venue').value = evt.venue_id;
            
            syncArtistBadges(evt.artist_ids || '');

            document.getElementById('fe-description').value = evt.description;
            document.getElementById('ticket-cat-list').innerHTML = '';
            ticketRowIdx = 0;
            if (evt.ticket_categories && evt.ticket_categories.length) {
              evt.ticket_categories.forEach(function (tc) { addTicketRow({ name: tc.category_name, price: tc.price, quota: tc.quota }); });
            }
            document.getElementById('event-modal-title').textContent = 'Edit Event';
            document.getElementById('event-modal-copy').textContent = 'Perbarui data event anda';
            document.getElementById('event-submit-btn').textContent = 'Simpan Perubahan';
            openModal('modal-event-form');
          };

          // Form Submit (Create/Edit)
          document.getElementById('form-event').addEventListener('submit', async function (e) {
            e.preventDefault();
            const mode = document.getElementById('fe-mode').value;
            const eventId = document.getElementById('fe-event-id').value;

            // Collect ticket categories
            const tcRows = document.querySelectorAll('.ticket-cat-row');
            const categories = [];
            tcRows.forEach(function (row) {
              categories.push({
                name: row.querySelector('.tc-name').value,
                price: Number(row.querySelector('.tc-price').value),
                quota: Number(row.querySelector('.tc-quota').value)
              });
            });

              const artistsArr = Array.from(document.querySelectorAll('.artist-badge')).map(badge => badge.dataset.val);
              if (artistsArr.length === 0) {
                showErrorToast('Silakan pilih minimal 1 artist');
                return;
              }
              const payload = {
                title: document.getElementById('fe-title').value,
                date: document.getElementById('fe-date').value,
                time: document.getElementById('fe-time').value,
                venue_id: document.getElementById('fe-venue').value,
                artists: artistsArr,
                description: document.getElementById('fe-description').value,
                ticket_categories: categories
              };

            try {
              let url, method;
              const currentUsername = "<%= user.username %>";
              if (mode === 'edit') { url = '/api/events/' + eventId + '?username=' + encodeURIComponent(currentUsername); method = 'PUT'; }
              else { url = '/api/events?username=' + encodeURIComponent(currentUsername); method = 'POST'; }

              const res = await fetch(url, { method: method, headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload) });
              const data = await res.json();
              if (data.success) {
                closeModal('modal-event-form');
                showSuccessToast(data.message);
                setTimeout(function () { location.reload(); }, 800);
              } else {
                showErrorToast(data.message || 'Gagal menyimpan event');
              }
            } catch (err) { showErrorToast('Error: ' + err.message); }
          });

          // ESC key
          document.addEventListener('keydown', function (e) {
            if (e.key === 'Escape') { ['modal-event-form'].forEach(function (id) { var el = document.getElementById(id); if (el && el.classList.contains('is-open')) closeModal(id); }); }
          });
        })();
      </script>

      <%- include('partials/footer') %>