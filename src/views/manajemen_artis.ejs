<%- include('partials/header', { title: 'Daftar Artis - TikTakTuk' }) %>

<main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-8">
        <div>
            <h1 class="text-2xl font-bold text-[#5c4a3d] mb-2">Daftar Artis</h1>
            <p class="text-stone-500 text-sm">Kelola artis yang ada di platform TikTakTuk</p>
        </div>
        <button 
            type="button"
            onclick="openModal('modalCreate')"
            class="inline-flex items-center gap-2 px-5 py-2.5 bg-[#5c4a3d] hover:bg-[#4a3b31] text-white text-sm font-medium rounded-md transition-colors shadow-sm"
        >
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" /></svg>
            Tambah Artis
        </button>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 mb-8">
        <div class="bg-white rounded-lg border border-[#e8e4dc] p-6 shadow-sm">
            <h3 class="text-xs font-bold text-stone-400 uppercase tracking-wider mb-2">Total Artis</h3>
            <p class="text-2xl font-bold text-[#5c4a3d]">6</p>
        </div>
        <div class="bg-white rounded-lg border border-[#e8e4dc] p-6 shadow-sm">
            <h3 class="text-xs font-bold text-stone-400 uppercase tracking-wider mb-2">Genre</h3>
            <p class="text-2xl font-bold text-[#5c4a3d]">6</p>
        </div>
        <div class="bg-white rounded-lg border border-[#e8e4dc] p-6 shadow-sm">
            <h3 class="text-xs font-bold text-stone-400 uppercase tracking-wider mb-2">Tampil Di Event</h3>
            <p class="text-2xl font-bold text-[#5c4a3d]">6</p>
        </div>
    </div>

    <div class="flex flex-col sm:flex-row justify-between items-center gap-4 mb-6">
        <div class="relative w-full sm:w-96">
            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                <svg class="h-4 w-4 text-stone-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                </svg>
            </div>
            <input type="text" placeholder="Cari nama atau genre..." class="w-full pl-9 pr-4 py-2 bg-white border border-[#e8e4dc] rounded-md text-sm text-stone-600 focus:outline-none focus:border-[#7f6c56] focus:ring-1 focus:ring-[#7f6c56] transition-colors">
        </div>

        <div class="text-xs text-stone-400 font-medium hidden sm:block">
            6 artis ditemukan
        </div>
    </div>

    <div class="text-xs text-stone-400 font-medium sm:hidden mb-4">
        6 artis ditemukan
    </div>

    <div class="bg-white rounded-lg border border-[#e8e4dc] overflow-x-auto shadow-sm">
        <table class="w-full text-left border-collapse min-w-[800px]">
            <thead>
                <tr class="bg-[#f5f3ef] border-b border-[#e8e4dc] text-xs font-bold text-stone-500 uppercase tracking-wider">
                    <th class="px-6 py-4">Artis</th>
                    <th class="px-6 py-4">Genre</th>
                    <th class="px-6 py-4 text-center">Aksi</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-[#e8e4dc] text-sm text-stone-600">
                <!-- rows preserved from original -->
            </tbody>
        </table>
    </div>
</main>

<!-- modals kept identical to original -->

<%- include('partials/footer') %>
