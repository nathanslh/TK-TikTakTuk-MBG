<!DOCTYPE html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= typeof title !== 'undefined' ? title : 'TikTakTuk' %></title>
    <% if (Array.isArray(meta)) { %>
      <% meta.forEach(function (metaTag) { %>
        <% if (!metaTag || typeof metaTag !== 'object') { return; } %>
        <% if (metaTag.name && metaTag.content) { %>
          <meta name="<%= metaTag.name %>" content="<%= metaTag.content %>" />
        <% } else if (metaTag.property && metaTag.content) { %>
          <meta property="<%= metaTag.property %>" content="<%= metaTag.content %>" />
        <% } else if (metaTag.httpEquiv && metaTag.content) { %>
          <meta http-equiv="<%= metaTag.httpEquiv %>" content="<%= metaTag.content %>" />
        <% } %>
      <% }) %>
    <% } %>
    <% if (typeof styles !== 'undefined' && Array.isArray(styles)) { %>
      <% styles.forEach(function (styleHref) { %>
        <link rel="stylesheet" href="<%= styleHref %>" />
      <% }) %>
    <% } %>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/dompurify@3.0.5/dist/purify.min.js"></script>
    <link rel="stylesheet" href="/css/global.css" />
  </head>
  <body class="site-bg text-stone-800 antialiased">
    <%- include('navbar', { user: (typeof user !== 'undefined' ? user : null) }) %>
