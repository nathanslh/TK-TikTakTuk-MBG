<div id="toast-root" style="position: fixed; bottom: 28px; right: 28px; z-index: 999; pointer-events: none;"></div>

<style>
  .toast {
    background: #111827;
    color: #fff;
    padding: 12px 18px;
    border-radius: 10px;
    font-size: 14px;
    max-width: 340px;
    line-height: 1.5;
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.15);
    margin-bottom: 12px;
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 0.25s, transform 0.25s;
    pointer-events: auto;
    animation: slideIn 0.3s ease-out forwards;
  }

  .toast.toast-error {
    background: #DC2626;
  }

  .toast.toast-success {
    background: #059669;
  }

  @keyframes slideIn {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes slideOut {
    from {
      opacity: 1;
      transform: translateY(0);
    }
    to {
      opacity: 0;
      transform: translateY(8px);
    }
  }
</style>
