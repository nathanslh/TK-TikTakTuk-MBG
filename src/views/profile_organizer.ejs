<%- include('partials/header', { title: 'Profil Organizer - TikTakTuk' }) %>

<main class="profile-wrap">
    <div class="profile-layout profile-layout-customer">
        <aside class="profile-sidebar profile-sidebar-customer">
            <div class="profile-sidebar-head">
                <div class="profile-avatar profile-avatar-customer" aria-hidden="true" data-profile-avatar><%= (organizer && organizer.name ? organizer.name : 'O').charAt(0).toUpperCase() %></div>
                <div>
                    <p class="profile-kicker">Akun Organizer</p>
                    <h1 class="profile-title profile-title-sidebar" data-profile-title data-profile-summary-name><%= organizer && organizer.name ? organizer.name : 'Profil Organizer' %></h1>
                    <p class="profile-subtitle profile-subtitle-sidebar">Kelola identitas organizer Anda.</p>
                </div>
            </div>

            <div class="profile-summary-card">
                <div class="profile-summary-row"><span>Username</span><strong data-profile-summary-username><%= organizer && organizer.username ? '@' + organizer.username : '-' %></strong></div>
                <div class="profile-summary-row"><span>Email</span><strong data-profile-summary-email><%= organizer && organizer.email ? organizer.email : '-' %></strong></div>
                <div class="profile-summary-row"><span>Kontak</span><strong data-profile-summary-phone><%= organizer && organizer.phone_number ? organizer.phone_number : '-' %></strong></div>
            </div>

            <div class="profile-action-stack">
                <button type="button" class="profile-btn profile-btn-secondary" data-open-password-modal data-password-title="Ubah Password" data-password-copy="Perbarui password untuk keamanan akun organizer.">Ubah Password</button>
                <button type="button" class="profile-btn profile-btn-primary" data-profile-edit>Edit Profil</button>
            </div>
        </aside>

        <section class="profile-card profile-panel">
            <header class="profile-card-head profile-panel-head">
                <div>
                    <p class="profile-panel-eyebrow">Informasi Profil</p>
                </div>
                <span class="profile-role-badge profile-role-customer">Organizer</span>
            </header>

            <form action="/profile/update" method="post" class="profile-grid-form" data-profile-form>
                <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
                <input type="hidden" name="role" value="ORGANIZER">
                <input type="hidden" name="current_username" value="<%= organizer && organizer.username ? organizer.username : '' %>">
                <div class="profile-field profile-field-full">
                    <label for="organizer-name">Nama Organizer</label>
                    <input id="organizer-name" name="organizer_name" type="text" value="<%= organizer && organizer.name ? organizer.name : '' %>" data-profile-editable disabled>
                </div>

                <div class="profile-field profile-field-full">
                    <label for="organizer-email">Email</label>
                    <input id="organizer-email" name="contact_email" type="email" value="<%= organizer && organizer.email ? organizer.email : '' %>" data-profile-editable disabled>
                </div>

                <div class="profile-field profile-field-full">
                    <label for="organizer-username">Username</label>
                    <input id="organizer-username" name="username" type="text" value="<%= organizer && organizer.username ? organizer.username : '' %>" data-profile-editable pattern="[A-Za-z0-9]+" title="Username hanya boleh berisi huruf dan angka tanpa titik atau simbol" disabled>
                </div>

                <div class="profile-inline-actions" hidden>
                    <button type="button" class="profile-btn profile-btn-ghost" data-profile-cancel hidden>Batal</button>
                    <button type="submit" class="profile-btn profile-btn-primary" data-profile-save hidden>Simpan Perubahan</button>
                </div>
            </form>
        </section>
    </div>
</main>

<%- include('partials/footer') %>
