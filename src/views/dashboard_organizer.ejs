<%- include('partials/header', { title: 'Dashboard Organizer - TikTakTuk' }) %>

<main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <!-- Header Card -->
  <div class="bg-slate-900 rounded-2xl p-8 mb-8 flex flex-col md:flex-row justify-between items-start md:items-center shadow-lg">
    <div class="mb-6 md:mb-0">
      <p class="text-slate-400 text-sm font-medium mb-1">Dashboard Penyelenggara</p>
      <h1 class="text-3xl font-bold text-white mb-2"><%= typeof organizerName !== 'undefined' ? organizerName : 'Organizer' %></h1>
      <p class="text-slate-400 text-sm">Kelola <%= typeof eventCount !== 'undefined' ? eventCount : 0 %> acara aktif Anda</p>
    </div>
    <div class="flex gap-3">
      <button class="bg-white text-slate-900 px-5 py-2.5 rounded-full font-semibold text-sm hover:bg-slate-100 transition-colors">
        Kelola Acara
      </button>
      <button class="bg-slate-800 text-white px-5 py-2.5 rounded-full font-semibold text-sm hover:bg-slate-700 transition-colors border border-slate-700">
        Venue
      </button>
    </div>
  </div>

  <!-- Stats Grid -->
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
    <!-- Acara Aktif -->
    <div class="bg-white rounded-2xl border border-slate-100 p-6 shadow-sm">
      <div class="flex justify-between items-start mb-4">
        <p class="text-xs font-bold text-slate-400 uppercase tracking-wider">Acara Aktif</p>
        <div class="w-10 h-10 rounded-xl bg-blue-50 text-blue-500 flex items-center justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
        </div>
      </div>
      <p class="text-3xl font-bold text-slate-800 mb-1"><%= typeof eventCount !== 'undefined' ? eventCount : 0 %></p>
      <p class="text-xs text-slate-500">Dalam koordinasi</p>
    </div>

    <!-- Tiket Terjual -->
    <div class="bg-white rounded-2xl border border-slate-100 p-6 shadow-sm">
      <div class="flex justify-between items-start mb-4">
        <p class="text-xs font-bold text-slate-400 uppercase tracking-wider">Tiket Terjual</p>
        <div class="w-10 h-10 rounded-xl bg-green-50 text-green-500 flex items-center justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z" />
          </svg>
        </div>
      </div>
      <p class="text-3xl font-bold text-slate-800 mb-1"><%= typeof ticketsSold !== 'undefined' ? ticketsSold : 0 %></p>
      <p class="text-xs text-slate-500">Total terjual</p>
    </div>

    <!-- Revenue -->
    <div class="bg-white rounded-2xl border border-slate-100 p-6 shadow-sm">
      <div class="flex justify-between items-start mb-4">
        <p class="text-xs font-bold text-slate-400 uppercase tracking-wider">Revenue</p>
        <div class="w-10 h-10 rounded-xl bg-purple-50 text-purple-500 flex items-center justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
          </svg>
        </div>
      </div>
      <p class="text-3xl font-bold text-slate-800 mb-1"><%= typeof revenue !== 'undefined' ? revenue : 'Rp 0' %></p>
      <p class="text-xs text-slate-500">Bulan ini</p>
    </div>

    <!-- Venue Mitra -->
    <div class="bg-white rounded-2xl border border-slate-100 p-6 shadow-sm">
      <div class="flex justify-between items-start mb-4">
        <p class="text-xs font-bold text-slate-400 uppercase tracking-wider">Venue Mitra</p>
        <div class="w-10 h-10 rounded-xl bg-orange-50 text-orange-500 flex items-center justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
        </div>
      </div>
      <% 
        let uniqueVenues = 3;
        if (typeof upcomingEvents !== 'undefined' && Array.isArray(upcomingEvents)) {
          const venues = new Set();
          upcomingEvents.forEach(e => venues.add(e.venue));
          if(venues.size > 0) uniqueVenues = venues.size;
        }
      %>
      <p class="text-3xl font-bold text-slate-800 mb-1"><%= uniqueVenues %></p>
      <p class="text-xs text-slate-500">Lokasi aktif</p>
    </div>
  </div>

  <!-- Performa Acara Section -->
  <div class="bg-white rounded-2xl border border-slate-100 shadow-sm overflow-hidden">
    <div class="p-6 border-b border-slate-100 flex justify-between items-start md:items-center">
      <div>
        <h2 class="text-lg font-bold text-slate-800 mb-1">Performa Acara</h2>
        <p class="text-sm text-slate-500">Status acara yang Anda kelola</p>
      </div>
      <a href="#" class="text-blue-600 font-semibold text-sm hover:text-blue-700">Lihat Semua</a>
    </div>

    <div class="divide-y divide-slate-100">
      <% if (typeof upcomingEvents !== 'undefined' && Array.isArray(upcomingEvents) && upcomingEvents.length > 0) { %>
        <% upcomingEvents.forEach(function (event) { %>
          <div class="p-6 hover:bg-slate-50 transition-colors cursor-pointer flex justify-between items-center group">
            <div>
              <div class="flex items-center gap-3 mb-2">
                <h3 class="font-bold text-slate-800 text-base"><%= event.name %></h3>
                <% if (event.status === 'active' || event.status === 'LIVE') { %>
                  <span class="bg-green-100 text-green-700 text-[10px] font-bold px-2 py-0.5 rounded-sm uppercase tracking-wider">LIVE</span>
                <% } else { %>
                  <span class="bg-slate-100 text-slate-600 text-[10px] font-bold px-2 py-0.5 rounded-sm uppercase tracking-wider"><%= event.status %></span>
                <% } %>
              </div>
              <div class="flex items-center text-sm text-slate-500 gap-4">
                <div class="flex items-center gap-1 text-green-600">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
                  </svg>
                  <span class="font-medium"><%= event.tickets_sold %> tiket terjual</span>
                </div>
                <div class="flex items-center gap-1">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                  </svg>
                  <span><%= event.venue %></span>
                </div>
              </div>
            </div>
            <div class="text-slate-300 group-hover:text-slate-500 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </div>
          </div>
        <% }) %>
      <% } else { %>
        <div class="p-8 text-center text-slate-500">
          Belum ada event yang dikelola.
        </div>
      <% } %>
    </div>
  </div>
</main>

<%- include('partials/footer') %>
