<%- include('partials/header', { title: 'Customer Dashboard - TikTakTuk' }) %>

<main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <!-- Header Card -->
  <div class="bg-blue-600 rounded-2xl p-8 mb-8 flex flex-col md:flex-row justify-between items-start md:items-center shadow-lg">
    <div class="mb-6 md:mb-0">
      <p class="text-blue-200 text-sm font-medium mb-1">Selamat datang kembali</p>
      <h1 class="text-3xl font-bold text-white mb-2"><%= typeof customerName !== 'undefined' ? customerName : 'Customer' %></h1>
      <p class="text-blue-200 text-sm"><%= typeof eventCount !== 'undefined' ? eventCount : 0 %> acara menarik menunggu Anda</p>
    </div>
    <a href="/events?username=<%= encodeURIComponent(user.username) %>" class="bg-white text-blue-600 px-6 py-2.5 rounded-full font-semibold text-sm hover:bg-blue-50 transition-colors shadow-sm text-center">
      Cari Tiket
    </a>
  </div>

  <!-- Stats Grid -->
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
    <!-- Tiket Aktif -->
    <div class="bg-white rounded-2xl border border-slate-100 p-6 shadow-sm">
      <div class="flex justify-between items-start mb-4">
        <p class="text-xs font-bold text-slate-400 uppercase tracking-wider">Tiket Aktif</p>
        <div class="w-10 h-10 rounded-xl bg-blue-50 text-blue-500 flex items-center justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z" />
          </svg>
        </div>
      </div>
      <p class="text-3xl font-bold text-slate-800 mb-1"><%= typeof ticketCount !== 'undefined' ? ticketCount : 0 %></p>
      <p class="text-xs text-slate-500">Siap digunakan</p>
    </div>

    <!-- Acara Diikuti -->
    <div class="bg-white rounded-2xl border border-slate-100 p-6 shadow-sm">
      <div class="flex justify-between items-start mb-4">
        <p class="text-xs font-bold text-slate-400 uppercase tracking-wider">Acara Diikuti</p>
        <div class="w-10 h-10 rounded-xl bg-green-50 text-green-500 flex items-center justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
        </div>
      </div>
      <p class="text-3xl font-bold text-slate-800 mb-1"><%= typeof eventCount !== 'undefined' ? eventCount : 0 %></p>
      <p class="text-xs text-slate-500">Total pengalaman</p>
    </div>

    <!-- Kode Promo -->
    <div class="bg-white rounded-2xl border border-slate-100 p-6 shadow-sm">
      <div class="flex justify-between items-start mb-4">
        <p class="text-xs font-bold text-slate-400 uppercase tracking-wider">Kode Promo</p>
        <div class="w-10 h-10 rounded-xl bg-purple-50 text-purple-500 flex items-center justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
          </svg>
        </div>
      </div>
      <p class="text-3xl font-bold text-slate-800 mb-1"><%= typeof promoCount !== 'undefined' ? promoCount : 0 %></p>
      <p class="text-xs text-slate-500">Tersedia untuk Anda</p>
    </div>

    <!-- Total Belanja -->
    <div class="bg-white rounded-2xl border border-slate-100 p-6 shadow-sm">
      <div class="flex justify-between items-start mb-4">
        <p class="text-xs font-bold text-slate-400 uppercase tracking-wider">Total Belanja</p>
        <div class="w-10 h-10 rounded-xl bg-orange-50 text-orange-500 flex items-center justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3" />
          </svg>
        </div>
      </div>
      <p class="text-3xl font-bold text-slate-800 mb-1"><%= typeof totalSpent !== 'undefined' ? totalSpent : 'Rp 0' %></p>
      <p class="text-xs text-slate-500">Bulan ini</p>
    </div>
  </div>

  <!-- Tiket Mendatang Section -->
  <div class="bg-white rounded-2xl border border-slate-100 shadow-sm overflow-hidden">
    <div class="p-6 border-b border-slate-100 flex justify-between items-start md:items-center">
      <div>
        <h2 class="text-lg font-bold text-slate-800 mb-1">Tiket Mendatang</h2>
        <p class="text-sm text-slate-500">Tiket pertunjukan yang akan datang</p>
      </div>
      <a href="/my-tickets?username=<%= encodeURIComponent(user.username) %>" class="text-blue-600 font-semibold text-sm hover:text-blue-700">Lihat Semua</a>
    </div>

    <div class="divide-y divide-slate-100">
      <% if (Array.isArray(upcomingTickets) && upcomingTickets.length > 0) { %>
        <% upcomingTickets.forEach(function (ticket) { %>
          <div class="p-6 hover:bg-slate-50 transition-colors cursor-pointer flex justify-between items-center group">
            <div>
              <div class="flex items-center gap-3 mb-2">
                <h3 class="font-bold text-slate-800 text-base"><%= ticket.event_name %></h3>
                <span class="bg-blue-100 text-blue-700 text-[10px] font-bold px-2 py-0.5 rounded-sm uppercase tracking-wider"><%= ticket.tier %></span>
              </div>
              <div class="flex items-center text-sm text-slate-500 gap-4">
                <div class="flex items-center gap-1">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                  </svg>
                  <span><%= ticket.date %></span>
                </div>
                <div class="flex items-center gap-1">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                  </svg>
                  <span><%= ticket.venue %></span>
                </div>
              </div>
            </div>
            <div class="text-slate-300 group-hover:text-slate-500 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </div>
          </div>
        <% }) %>
      <% } else { %>
        <div class="p-8 text-center text-slate-500">
          Belum ada tiket mendatang.
        </div>
      <% } %>
    </div>
  </div>
</main>

<%- include('partials/footer') %>
