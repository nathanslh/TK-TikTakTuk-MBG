<%- include('partials/header', { title: 'Manajemen Artist - TikTakTuk' }) %>

<div class="seat-page">
  <div class="seat-shell">

    <!-- Header -->
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-6">
      <div class="page-heading">
        <h1 style="font-size:clamp(1.6rem,3vw,2.2rem);font-weight:800;color:var(--ink);letter-spacing:-0.03em;line-height:1.2;">Manajemen Artist</h1>
        <p class="auth-muted" style="margin-top:0.3rem;">Kelola data artist yang dapat tampil pada event</p>
      </div>
      <div class="flex gap-3">
        <% if (user && user.role === 'ADMIN') { %>
          <button type="button" onclick="openAddModal()" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full font-bold text-sm text-white" style="background:linear-gradient(145deg,var(--accent),#a87542);box-shadow:0 10px 20px rgba(131,88,42,.16);">
            + Tambah Artist
          </button>
        <% } %>
      </div>
    </div>

    <!-- Daftar Artist -->
    <div class="seat-card" style="padding:1.5rem;" id="artist-list">
      <div class="overflow-x-auto">
        <table class="w-full text-left" style="min-width:600px;border-collapse:collapse;">
          <thead>
            <tr style="border-bottom:2px solid var(--border);">
              <th style="padding:1rem 0.5rem;font-weight:700;color:var(--muted);font-size:0.85rem;text-transform:uppercase;letter-spacing:0.05em;">Name</th>
              <th style="padding:1rem 0.5rem;font-weight:700;color:var(--muted);font-size:0.85rem;text-transform:uppercase;letter-spacing:0.05em;">Genre</th>
              <% if (user && user.role === 'ADMIN') { %>
                <th style="padding:1rem 0.5rem;font-weight:700;color:var(--muted);font-size:0.85rem;text-transform:uppercase;letter-spacing:0.05em;text-align:center;">Action</th>
              <% } %>
            </tr>
          </thead>
          <tbody>
            <% if (typeof artists !== 'undefined' && artists.length > 0) { %>
              <% artists.forEach(function(artist) { %>
                <tr style="border-bottom:1px solid var(--border);transition:background 0.2s;" onmouseover="this.style.background='rgba(185,133,78,.03)'" onmouseout="this.style.background='transparent'">
                  <td style="padding:1rem 0.5rem;font-weight:600;color:var(--ink);"><%= artist.name %></td>
                  <td style="padding:1rem 0.5rem;color:var(--muted);"><%= artist.genre || '-' %></td>
                  <% if (user && user.role === 'ADMIN') { %>
                    <td style="padding:1rem 0.5rem;text-align:center;">
                      <div style="display:flex;gap:0.5rem;justify-content:center;">
                        <button type="button" 
                          data-id="<%= artist.artist_id %>"
                          data-name="<%= artist.name %>"
                          data-genre="<%= artist.genre || '' %>"
                          onclick="openEditModal(this.getAttribute('data-id'), this.getAttribute('data-name'), this.getAttribute('data-genre'))" 
                          class="btn-edit-premium">
                          <svg style="width:13px;height:13px;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                          </svg>
                          Edit
                        </button>
                        <button type="button" 
                          data-id="<%= artist.artist_id %>"
                          data-name="<%= artist.name %>"
                          onclick="openDeleteModal(this.getAttribute('data-id'), this.getAttribute('data-name'))" 
                          class="btn-hapus-premium">
                          <svg style="width:13px;height:13px;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                          </svg>
                          Hapus
                        </button>
                      </div>
                    </td>
                  <% } %>
                </tr>
              <% }) %>
            <% } else { %>
              <tr>
                <td colspan="<%= (user && user.role === 'ADMIN') ? 3 : 2 %>" style="text-align:center;padding:2rem;color:var(--muted);">Belum ada artist terdaftar.</td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<!-- Modal Create/Update Artist -->
<div class="seat-modal" id="modal-artist-form">
  <div class="seat-modal-panel" style="max-width:500px;">
    <div style="padding:1.25rem;display:flex;justify-content:space-between;align-items:flex-start;border-bottom:1px solid rgba(185,133,78,.14);">
      <div>
        <h2 id="artist-modal-title" style="font-size:1.35rem;font-weight:800;color:var(--ink);">Create Artist</h2>
        <p id="artist-modal-desc" class="auth-muted" style="margin-top:0.3rem;">Isi form berikut untuk menambahkan artist baru.</p>
      </div>
      <button type="button" onclick="closeModal('modal-artist-form')" class="auth-modal-close">x</button>
    </div>
    <form id="form-artist" style="padding:1.25rem;">
      <input type="hidden" name="artist_id" id="fa-id">
      <input type="hidden" name="mode" id="fa-mode" value="create">

      <div class="seat-form-grid" style="grid-template-columns:1fr;">
        <div>
          <label class="seat-form-label">Name (Nama Artist) <span style="color:var(--accent-strong);">*</span></label>
          <input type="text" name="name" id="fa-name" class="form-input" placeholder="Masukkan nama artist" required>
        </div>
        <div>
          <label class="seat-form-label">Genre (Opsional)</label>
          <input type="text" name="genre" id="fa-genre" class="form-input" placeholder="Contoh: Pop, Rock, Jazz">
        </div>
      </div>

      <div style="margin-top:2rem;display:flex;justify-content:flex-end;gap:1rem;">
        <button type="button" onclick="closeModal('modal-artist-form')" class="px-5 py-2.5 rounded-xl font-bold text-sm" style="color:var(--ink);background:rgba(255,255,255,.6);border:1px solid var(--border);">Batal</button>
        <button type="submit" id="btn-submit-artist" class="px-5 py-2.5 rounded-xl font-bold text-sm text-white" style="background:linear-gradient(145deg,var(--accent),#a87542);box-shadow:0 8px 16px rgba(131,88,42,.2);">Create</button>
      </div>
    </form>
  </div>
</div>

<!-- Modal Delete Artist -->
<div class="seat-modal" id="modal-delete-artist">
  <div class="seat-modal-panel" style="max-width:400px;text-align:center;">
    <div style="padding:2rem 1.5rem;">
      <div style="width:60px;height:60px;border-radius:50%;background:#fee2e2;color:#dc2626;display:flex;align-items:center;justify-content:center;margin:0 auto 1.5rem;">
        <svg style="width:30px;height:30px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
      </div>
      <h2 style="font-size:1.35rem;font-weight:800;color:var(--ink);margin-bottom:0.5rem;">Delete Artist</h2>
      <p class="auth-muted" style="font-size:0.95rem;margin-bottom:1rem;">Apakah Anda yakin ingin menghapus artist ini? Tindakan ini tidak dapat dibatalkan.</p>
      
      <div style="background:#f8f9fa;border-radius:8px;padding:1rem;margin-bottom:1.5rem;text-align:left;">
        <p style="font-size:0.75rem;color:var(--muted);margin-bottom:0.2rem;text-transform:uppercase;letter-spacing:0.05em;font-weight:700;">Artist ID</p>
        <p id="del-artist-id" style="font-family:monospace;font-size:0.85rem;color:var(--ink);margin-bottom:0.8rem;word-break:break-all;"></p>
        
        <p style="font-size:0.75rem;color:var(--muted);margin-bottom:0.2rem;text-transform:uppercase;letter-spacing:0.05em;font-weight:700;">Name</p>
        <p id="del-artist-name" style="font-size:0.95rem;font-weight:700;color:var(--ink);"></p>
      </div>

      <input type="hidden" id="del-id">
      
      <div style="display:flex;gap:1rem;">
        <button type="button" onclick="closeModal('modal-delete-artist')" style="flex:1;padding:0.75rem;border-radius:12px;font-weight:700;color:var(--ink);background:var(--card-bg);border:1px solid var(--border);">Cancel</button>
        <button type="button" onclick="confirmDeleteArtist()" style="flex:1;padding:0.75rem;border-radius:12px;font-weight:700;color:white;background:#dc2626;border:none;box-shadow:0 4px 12px rgba(220,38,38,.2);">Confirm Deletion</button>
      </div>
    </div>
  </div>
</div>

<script>
function openModal(id) {
  document.getElementById(id).classList.add('is-open');
  document.body.style.overflow = 'hidden';
}
function closeModal(id) {
  document.getElementById(id).classList.remove('is-open');
  document.body.style.overflow = '';
}

function openAddModal() {
  document.getElementById('form-artist').reset();
  document.getElementById('fa-mode').value = 'create';
  document.getElementById('fa-id').value = '';
  document.getElementById('artist-modal-title').textContent = 'Create Artist';
  document.getElementById('artist-modal-desc').textContent = 'Isi form berikut untuk menambahkan artist baru.';
  document.getElementById('btn-submit-artist').textContent = 'Create';
  openModal('modal-artist-form');
}

function openEditModal(id, name, genre) {
  document.getElementById('form-artist').reset();
  document.getElementById('fa-mode').value = 'update';
  document.getElementById('fa-id').value = id;
  document.getElementById('fa-name').value = name;
  document.getElementById('fa-genre').value = genre;
  document.getElementById('artist-modal-title').textContent = 'Update Artist';
  document.getElementById('artist-modal-desc').textContent = 'Ubah detail artist yang sudah ada.';
  document.getElementById('btn-submit-artist').textContent = 'Update';
  openModal('modal-artist-form');
}

function openDeleteModal(id, name) {
  document.getElementById('del-id').value = id;
  document.getElementById('del-artist-id').textContent = id;
  document.getElementById('del-artist-name').textContent = name;
  openModal('modal-delete-artist');
}

document.getElementById('form-artist').addEventListener('submit', async (e) => {
  e.preventDefault();
  const mode = document.getElementById('fa-mode').value;
  const id = document.getElementById('fa-id').value;
  
  const payload = {
    name: document.getElementById('fa-name').value.trim(),
    genre: document.getElementById('fa-genre').value.trim()
  };

  if (!payload.name) {
    showToast('Name wajib diisi.', 'error');
    return;
  }

  const url = mode === 'create' ? '/api/artists' : `/api/artists/${id}`;
  const method = mode === 'create' ? 'POST' : 'PUT';
  const btn = document.getElementById('btn-submit-artist');
  const originalText = btn.textContent;

  try {
    btn.textContent = 'Menyimpan...';
    btn.disabled = true;

    const res = await fetch(url, {
      method,
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload)
    });
    const data = await res.json();
    if (data.success) {
      showToast(data.message, 'success');
      closeModal('modal-artist-form');
      setTimeout(() => window.location.reload(), 1000);
    } else {
      showToast(data.message, 'error');
    }
  } catch (err) {
    showToast('Terjadi kesalahan sistem.', 'error');
  } finally {
    btn.textContent = originalText;
    btn.disabled = false;
  }
});

async function confirmDeleteArtist() {
  const id = document.getElementById('del-id').value;
  try {
    const res = await fetch(`/api/artists/${id}`, { method: 'DELETE' });
    const data = await res.json();
    if (data.success) {
      showToast(data.message, 'success');
      closeModal('modal-delete-artist');
      setTimeout(() => window.location.reload(), 1000);
    } else {
      showToast(data.message, 'error');
    }
  } catch (err) {
    showToast('Terjadi kesalahan sistem.', 'error');
  }
}
</script>

<%- include('partials/footer') %>
