<%- include('partials/header', { title: 'Profil Admin - TikTakTuk' }) %>

<main class="profile-wrap">
  <div class="profile-layout profile-layout-customer">
    <aside class="profile-sidebar profile-sidebar-customer">
      <div class="profile-sidebar-head">
        <div class="profile-avatar profile-avatar-customer" aria-hidden="true" data-profile-avatar><%= (admin && admin.display_name ? admin.display_name : 'A').charAt(0).toUpperCase() %></div>
        <div>
          <p class="profile-kicker">Akun Admin</p>
          <h1 class="profile-title profile-title-sidebar" data-profile-title data-profile-summary-name><%= admin && admin.display_name ? admin.display_name : 'Profil Admin' %></h1>
          <p class="profile-subtitle profile-subtitle-sidebar">Akun admin untuk pengelolaan sistem.</p>
        </div>
      </div>

      <div class="profile-summary-card">
        <div class="profile-summary-row"><span>Username</span><strong data-profile-summary-username><%= admin && admin.username ? '@' + admin.username : '-' %></strong></div>
      </div>

      <div class="profile-action-stack">
        <button type="button" class="profile-btn profile-btn-secondary" data-open-password-modal data-password-title="Ubah Password" data-password-copy="Perbarui password untuk keamanan akun admin.">Ubah Password</button>
        <button type="button" class="profile-btn profile-btn-primary" data-profile-edit>Edit Profil</button>
      </div>
    </aside>

    <section class="profile-card profile-panel">
      <header class="profile-card-head profile-panel-head">
        <div>
          <p class="profile-panel-eyebrow">Informasi Profil</p>
        </div>
        <span class="profile-role-badge profile-role-customer">Admin</span>
      </header>

      <form action="/profile/update" method="post" class="profile-grid-form" data-profile-form>
        <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
        <input type="hidden" name="role" value="ADMIN">
        <input type="hidden" name="current_username" value="<%= admin && admin.username ? admin.username : '' %>">

        <div class="profile-field profile-field-full">
          <label for="admin-username">Username</label>
          <input id="admin-username" name="username" type="text" value="<%= admin && admin.username ? admin.username : '' %>" data-profile-editable pattern="[A-Za-z0-9]+" title="Username hanya boleh berisi huruf dan angka tanpa titik atau simbol" disabled>
        </div>

        <div class="profile-inline-actions" hidden>
          <button type="button" class="profile-btn profile-btn-ghost" data-profile-cancel hidden>Batal</button>
          <button type="submit" class="profile-btn profile-btn-primary" data-profile-save hidden>Simpan Perubahan</button>
        </div>
      </form>
    </section>
  </div>
</main>

<%- include('partials/footer') %>